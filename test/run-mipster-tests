#!/bin/bash
# run-mipster-tests — run the MIPster test suite with concise pass/fail output.
#
# On success prints one line per test:  [N/T] TestName ... PASS (Xs)
# On failure prints the full test output below the FAIL line so problems are
# immediately visible without needing to re-run with --verbose.
#
# Fixture MPS files are located automatically:
#   1. $MIPSTER_FIXTURE_DIR  (env override)
#   2. <script_dir>/../share/mipster/test/fixtures   (installed FHS layout)
#   3. <script_dir>/fixtures                          (build-tree layout)
#
# Exit code: 0 if all tests pass, 1 if any fail.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Millisecond-precision epoch time. Falls back gracefully on platforms without GNU date.
get_epoch_ms() {
  python3 -c "import time; print(int(time.time()*1000))" 2>/dev/null || \
    { date +%s%3N 2>/dev/null; } || \
    echo $(( $(date +%s) * 1000 ))
}

DEBUG_MODE=0
WRITE_BASELINE_PLATFORM=""
WRITE_BASELINE_FILE=""

# Parse arguments
while [ $# -gt 0 ]; do
  case "$1" in
    --debug)
      DEBUG_MODE=1
      ;;
    --write-baseline)
      WRITE_BASELINE_PLATFORM="${2:-}"
      WRITE_BASELINE_FILE="${3:-}"
      shift 2
      ;;
    --help)
      echo "Usage: run-mipster-tests [--debug] [--write-baseline PLATFORM FILE]"
      echo ""
      echo "  --debug   Use lib/dbg/ library (with ASan on Linux). Sets LD_LIBRARY_PATH"
      echo "            (and LD_PRELOAD for ASan init if libasan is bundled)."
      echo "  --write-baseline PLATFORM FILE"
      echo "            Write CI baseline JSON to FILE after a successful run."
      echo "            PLATFORM is a human-readable string describing the CI machine."
      exit 0
      ;;
    *)
      echo "Unknown option: $1" >&2
      exit 1
      ;;
  esac
  shift
done

# ── Locate fixture directory ─────────────────────────────────────────────────
if [ -z "${MIPSTER_FIXTURE_DIR:-}" ]; then
  if [ -d "$SCRIPT_DIR/fixtures" ]; then
    MIPSTER_FIXTURE_DIR="$SCRIPT_DIR/fixtures"
  elif [ -d "$SCRIPT_DIR/../share/mipster/test/fixtures" ]; then
    MIPSTER_FIXTURE_DIR="$(cd "$SCRIPT_DIR/../share/mipster/test/fixtures" && pwd)"
  else
    echo "WARNING: fixture directory not found; MPS-based tests may fail." >&2
    MIPSTER_FIXTURE_DIR=""
  fi
fi
export MIPSTER_FIXTURE_DIR

# ── Debug library setup (--debug flag) ──────────────────────────────────────
if [ "$DEBUG_MODE" -eq 1 ]; then
  DBG_LIB_DIR=""
  # Look for lib/dbg/ relative to script (tarball layout: script is in bin/)
  if [ -d "${SCRIPT_DIR}/../lib/dbg" ]; then
    DBG_LIB_DIR="$(cd "${SCRIPT_DIR}/../lib/dbg" && pwd)"
  elif [ -d "${SCRIPT_DIR}/lib/dbg" ]; then
    DBG_LIB_DIR="$(cd "${SCRIPT_DIR}/lib/dbg" && pwd)"
  fi

  if [ -n "$DBG_LIB_DIR" ]; then
    export LD_LIBRARY_PATH="${DBG_LIB_DIR}${LD_LIBRARY_PATH:+:${LD_LIBRARY_PATH}}"
    export DYLD_LIBRARY_PATH="${DBG_LIB_DIR}${DYLD_LIBRARY_PATH:+:${DYLD_LIBRARY_PATH}}"
    # If libasan is bundled, preload it so ASan runtime initialises before user code.
    local_libasan=$(find "${DBG_LIB_DIR}" -name 'libasan.so.*' ! -type l 2>/dev/null | head -1)
    if [ -n "$local_libasan" ]; then
      export LD_PRELOAD="${local_libasan}${LD_PRELOAD:+:${LD_PRELOAD}}"
    fi
    export ASAN_OPTIONS="${ASAN_OPTIONS:-detect_leaks=0:abort_on_error=1}"
    echo "    debug library: $DBG_LIB_DIR"
  else
    echo "WARNING: --debug specified but lib/dbg/ not found; running with default library" >&2
  fi
fi

# ── Test list (order matters for readability) ────────────────────────────────
TESTS=(
  CInterfaceTest
  CInterfaceTest_tsp_random
  CInterfaceTest_fl_random
  CInterfaceTest_mdkp_random
  CInterfaceTest_miclsp
  CInterfaceTest_nursesched
  CInterfaceTest_a1
  CInterfaceTest_graphdraw
  CInterfaceTest_trdta5581
  CInterfaceTest_trd445c
  CInterfaceTest_j3041_1
  CInterfaceTest_yue20013
  CInterfaceTest_etDecsi
  CbcSolverLpTest
  CInterfaceTest_advanced
  CInterfaceTest_colgen
  CInterfaceTest_construction
  CInterfaceTest_facility
  CInterfaceTest_jssp
  CInterfaceTest_kantorovich
  CInterfaceTest_mip_reopt
  CInterfaceTest_new
  CInterfaceTest_tsp_cuts
)

TOTAL=${#TESTS[@]}
PASS=0
FAIL=0
FAILURES=()
TEST_RESULTS=()   # entries: "TestName:elapsed_ms"

# ── Helpers ──────────────────────────────────────────────────────────────────
# Width of the counter field (e.g. 2 for totals up to 99)
W=${#TOTAL}
# Fixed width for the test name column
NAME_COL=40

find_bin() {
  local name="$1"
  if [ -x "$SCRIPT_DIR/$name" ]; then echo "$SCRIPT_DIR/$name"
  elif [ -x "$SCRIPT_DIR/test/$name" ]; then echo "$SCRIPT_DIR/test/$name"
  elif command -v "$name" >/dev/null 2>&1; then command -v "$name"
  elif [ -x "./$name" ]; then echo "./$name"
  fi
}

# ── Run all tests in parallel ────────────────────────────────────────────────
echo "=== MIPster Test Suite ==="
[ -n "$MIPSTER_FIXTURE_DIR" ] && echo "    fixtures: $MIPSTER_FIXTURE_DIR"
echo ""

declare -a _pids _start_ms _tmpfiles _bins

# Phase 1: launch all tests in background
for i in "${!TESTS[@]}"; do
  name="${TESTS[$i]}"
  bin=$(find_bin "$name")
  tmpfile=$(mktemp)
  _tmpfiles[$i]="$tmpfile"
  _bins[$i]="$bin"
  _start_ms[$i]=$(get_epoch_ms)
  if [ -n "$bin" ]; then
    "$bin" > "$tmpfile" 2>&1 &
    _pids[$i]=$!
  else
    _pids[$i]=""
  fi
done

# Phase 2: collect results in launch order
for i in "${!TESTS[@]}"; do
  name="${TESTS[$i]}"
  idx=$(( i + 1 ))
  bin="${_bins[$i]}"
  tmpfile="${_tmpfiles[$i]}"
  pid="${_pids[$i]}"

  if [ -z "$bin" ]; then
    printf "[%*d/%d] %-*s SKIP  (not found)\n" "$W" "$idx" "$TOTAL" "$NAME_COL" "$name"
    rm -f "$tmpfile"
    continue
  fi

  wait "$pid" && rc=0 || rc=$?
  elapsed_ms=$(( $(get_epoch_ms) - _start_ms[$i] ))
  elapsed_s=$(awk "BEGIN { printf \"%.1f\", ${elapsed_ms}/1000 }" 2>/dev/null || echo "${elapsed_ms}")

  printf "[%*d/%d] %-*s" "$W" "$idx" "$TOTAL" "$NAME_COL" "$name"

  if [ "$rc" -eq 0 ]; then
    printf " PASS  (%ss)\n" "$elapsed_s"
    PASS=$(( PASS + 1 ))
    TEST_RESULTS+=("${name}:${elapsed_ms}")
  else
    printf " FAIL  (%ss)\n" "$elapsed_s"
    FAIL=$(( FAIL + 1 ))
    FAILURES+=("$name")
    TEST_RESULTS+=("${name}:${elapsed_ms}")
    sed 's/^/    | /' "$tmpfile"
    printf '    \n'
  fi
  rm -f "$tmpfile"
done

# ── Summary ──────────────────────────────────────────────────────────────────
echo ""
if [ "$FAIL" -eq 0 ]; then
  echo "All ${PASS} tests passed."

  # ── Write baseline (CI mode) ───────────────────────────────────────────────
  if [ -n "${WRITE_BASELINE_FILE:-}" ] && [ -n "${WRITE_BASELINE_PLATFORM:-}" ]; then
    mkdir -p "$(dirname "${WRITE_BASELINE_FILE}")"
    python3 - "${WRITE_BASELINE_PLATFORM}" "${WRITE_BASELINE_FILE}" "${TEST_RESULTS[@]}" << 'PYEOF'
import sys, json, datetime
platform_str = sys.argv[1]
out_file = sys.argv[2]
times = {}
for arg in sys.argv[3:]:
    name, ms = arg.rsplit(":", 1)
    times[name] = int(ms)
data = {
    "platform": platform_str,
    "generated": datetime.date.today().isoformat(),
    "times_ms": times
}
with open(out_file, "w") as f:
    json.dump(data, f, indent=2, sort_keys=True)
PYEOF
    echo "    Baseline written: ${WRITE_BASELINE_FILE}"
  fi

  # ── Comparison vs CI baseline (user mode) ─────────────────────────────────
  if [ -z "${WRITE_BASELINE_FILE:-}" ] && command -v python3 >/dev/null 2>&1; then
    # Locate the bundled CI baseline: script lives in bin/, baseline in share/mipster/test/
    BASELINE_FILE=""
    for candidate in \
      "${SCRIPT_DIR}/../share/mipster/test/ci-baseline-times.json" \
      "${SCRIPT_DIR}/share/mipster/test/ci-baseline-times.json"; do
      if [ -f "${candidate}" ]; then
        BASELINE_FILE="${candidate}"
        break
      fi
    done

    if [ -n "${BASELINE_FILE}" ]; then
      python3 - "${BASELINE_FILE}" "${TEST_RESULTS[@]}" << 'PYEOF'
import sys, json, math
baseline_file = sys.argv[1]
test_results = {}
for arg in sys.argv[2:]:
    name, ms = arg.rsplit(":", 1)
    test_results[name] = int(ms)

try:
    with open(baseline_file) as f:
        baseline = json.load(f)
    bl_times = baseline.get("times_ms", {})
    platform = baseline.get("platform", "unknown")
    date = baseline.get("generated", "unknown")
except Exception as e:
    sys.exit(0)   # silently skip if baseline can't be loaded

comparable = [(name, test_results[name], bl_times[name])
              for name in test_results if name in bl_times and test_results[name] > 0]
if not comparable:
    sys.exit(0)

W = 42
print(f"\n=== Performance vs CI baseline ===")
print(f"    Baseline: {platform} ({date})")
print(f"{'Test':<{W}} {'Yours':>8} {'CI':>8} {'Speedup':>10}")
print("-" * (W + 30))
ratios = []
for name, your_ms, ci_ms in sorted(comparable):
    ratio = ci_ms / max(your_ms, 1)
    ratios.append(ratio)
    sym = "↑" if ratio >= 1.0 else "↓"
    print(f"{name:<{W}} {your_ms/1000:>7.1f}s {ci_ms/1000:>7.1f}s  {sym}{ratio:>7.2f}x")
if len(ratios) >= 2:
    geomean = math.exp(sum(math.log(r) for r in ratios) / len(ratios))
    desc = "faster than" if geomean >= 1.0 else "slower than"
    print("-" * (W + 30))
    print(f"{'Geometric mean:':<{W}} {'':>8} {'':>8}  {geomean:>7.2f}x {desc} CI")
PYEOF
    fi
  fi
else
  echo "${FAIL}/${TOTAL} test(s) FAILED: ${FAILURES[*]}"
  exit 1
fi
